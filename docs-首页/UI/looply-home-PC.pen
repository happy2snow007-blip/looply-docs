        },
        {
          "type": "text",
          "id": "RqEWM",
          "name": "s5b",
          "fill": "#374151",
          "content": "- Card hover: Translate Y -4px + shadow increase (200ms ease-out)\n- Image hover: Show 'Quick View' overlay button (fade-in 200ms)\n- Wishlist heart icon: Toggle fill on click (scale bounce 1.0-1.2-1.0, 300ms)\n- 'View All' link: Hover arrow slides right 4px (200ms)\n- Click card: Navigate to /product/{id}\n- [DEV NOTE] Original price: Add text-decoration: line-through in CSS\n- [DEV NOTE] Discount badge: Consider pulse on viewport enter",
          "lineHeight": 1.7,
          "fontFamily": "DM Sans",
