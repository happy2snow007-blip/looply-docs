              "fill": "$a-text-body",
              "textGrowth": "fixed-width",
              "width": 343,
              "content": "Welcome to Looply. These Terms of Service govern your use of our platform and services. By accessing or using Looply, you agree to be bound by these terms.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "xI41k",
              "name": "tosH2",
              "fill": "$a-text-primary",
              "content": "1. Account Registration",
              "fontFamily": "DM Sans",
              "fontSize": 16,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "Joa9k",
              "name": "tosP2",
              "fill": "$a-text-body",
              "textGrowth": "fixed-width",
              "width": 343,
              "content": "To use certain features of our platform, you must create an account. You agree to provide accurate, current, and complete information during registration and to update such information to keep it accurate.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "gfI98",
              "name": "tosH3",
              "fill": "$a-text-primary",
              "content": "2. User Conduct",
              "fontFamily": "DM Sans",
              "fontSize": 16,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "amR7h",
              "name": "tosP3",
              "fill": "$a-text-body",
              "textGrowth": "fixed-width",
              "width": 343,
              "content": "You agree not to use the platform for any unlawful purpose or in any way that could damage, disable, or impair the service. You must not attempt to gain unauthorized access to any part of the platform.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "basMi",
              "name": "tosH4",
              "fill": "$a-text-primary",
              "content": "3. Intellectual Property",
              "fontFamily": "DM Sans",
              "fontSize": 16,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "9DbG6",
              "name": "tosP4",
              "fill": "$a-text-body",
              "textGrowth": "fixed-width",
              "width": 343,
              "content": "All content on Looply, including text, graphics, logos, and software, is the property of Looply or its content suppliers and is protected by international copyright laws.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            }
          ]
        }
      ]
