                  "name": "s6t",
                  "fill": "$text-primary",
                  "content": "6. Limitation of Liability",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "SCQ1U",
                  "name": "s6b",
                  "fill": "$text-secondary",
                  "content": "Looply shall not be liable for any indirect, incidental, special, or consequential damages arising from your use of the platform. Our total liability shall not exceed the amount you paid to Looply in the twelve months preceding the claim.",
