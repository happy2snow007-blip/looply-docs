                }
              ]
            },
            {
              "type": "frame",
              "id": "RMhbk",
              "name": "section-4",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "6TtiS",
                  "name": "s4t",
                  "fill": "$text-primary",
                  "content": "4. Intellectual Property",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "M0ynK",
                  "name": "s4b",
                  "fill": "$text-secondary",
                  "content": "All content on the Looply platform, including logos, text, graphics, and software, is the property of Looply or its licensors and is protected by intellectual property laws. You may not reproduce, distribute, or create derivative works without prior written consent.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "X2n6o",
              "name": "section-5",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "YHdfo",
                  "name": "s5t",
                  "fill": "$text-primary",
                  "content": "5. Transactions and Payments",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "xJfrm",
                  "name": "s5b",
                  "fill": "$text-secondary",
                  "content": "Looply facilitates transactions between buyers and sellers. All purchases are subject to our return and refund policy. We use third-party payment processors and do not store your full payment information on our servers.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
