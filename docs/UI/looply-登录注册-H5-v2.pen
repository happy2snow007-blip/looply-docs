                  "name": "s7t",
                  "fill": "$text-primary",
                  "content": "7. Termination",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "RsZk2",
                  "name": "s7b",
                  "fill": "$text-secondary",
                  "content": "We may suspend or terminate your account at any time if you violate these terms or engage in fraudulent activity. Upon termination, your right to use the platform ceases immediately. Provisions that by their nature should survive termination will remain in effect.",
