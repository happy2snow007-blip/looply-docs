              ]
            },
            {
              "type": "frame",
              "id": "Rq6ox",
              "name": "section-2",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "nRy8I",
                  "name": "secTitle12b",
                  "fill": "$text-primary",
                  "content": "2. User Accounts",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "6Tony",
                  "name": "secBody12b",
                  "fill": "$text-secondary",
                  "content": "You must provide accurate information when creating an account. You are responsible for maintaining the security of your account credentials and for all activities under your account.",
