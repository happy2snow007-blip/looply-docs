                  "type": "text",
                  "id": "zJhNy",
                  "name": "secTitle12c",
                  "fill": "$text-primary",
                  "content": "3. Prohibited Conduct",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "50EsN",
                  "name": "secBody12c",
                  "fill": "$text-secondary",
                  "content": "You agree not to engage in any activity that interferes with or disrupts the platform, including but not limited to fraud, harassment, or unauthorized data collection.",
