              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "fELFL",
                  "name": "secTitle12a",
                  "fill": "$text-primary",
                  "content": "1. Acceptance of Terms",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "iYBs9",
                  "name": "secBody12a",
                  "fill": "$text-secondary",
                  "content": "By accessing or using the Looply platform, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our services.",
