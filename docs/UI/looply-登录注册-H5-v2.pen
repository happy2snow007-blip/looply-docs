              "name": "title13",
              "fill": "$text-primary",
              "content": "Privacy Policy",
              "fontFamily": "DM Sans",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "ZDvPR",
              "name": "updated13",
              "fill": "$text-secondary",
              "content": "Last updated: March 1, 2026",
              "fontFamily": "DM Sans",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "ftUts",
              "name": "section-1",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "DcHsN",
                  "name": "secT13a",
                  "fill": "$text-primary",
                  "content": "1. Information We Collect",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "NPT07",
                  "name": "secB13a",
                  "fill": "$text-secondary",
                  "content": "We collect information you provide directly, such as your name, email address, and payment details. We also collect usage data automatically through cookies and similar technologies.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "a2A3Q",
              "name": "section-2",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "zs8Sv",
                  "name": "secT13b",
                  "fill": "$text-primary",
                  "content": "2. How We Use Your Information",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "9gkym",
                  "name": "secB13b",
                  "fill": "$text-secondary",
                  "content": "Your information is used to provide and improve our services, process transactions, communicate with you, and ensure platform security.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "BcNVZ",
              "name": "section-3",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "Y4j5C",
                  "name": "secT13c",
                  "fill": "$text-primary",
                  "content": "3. Data Protection Rights",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "Rqzct",
                  "name": "secB13c",
                  "fill": "$text-secondary",
                  "content": "Under GDPR and CCPA, you have the right to access, correct, delete, or port your personal data. Contact us at privacy@looply.com to exercise these rights.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "sZtH2",
              "name": "section-4",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "Ocgbf",
                  "name": "p4t",
                  "fill": "$text-primary",
                  "content": "4. Cookies and Tracking",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "NMYZj",
                  "name": "p4b",
                  "fill": "$text-secondary",
                  "content": "We use cookies and similar tracking technologies to enhance your experience, analyze usage patterns, and deliver personalized content. You can manage cookie preferences through your browser settings. Essential cookies are required for platform functionality.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "T1wlQ",
              "name": "section-5",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "4XT7Z",
                  "name": "p5t",
                  "fill": "$text-primary",
                  "content": "5. Data Sharing and Disclosure",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "RoIEH",
                  "name": "p5b",
                  "fill": "$text-secondary",
                  "content": "We may share your information with trusted third-party service providers who assist in operating our platform, processing payments, and delivering services. We do not sell your personal data to third parties for marketing purposes.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "sR7AG",
              "name": "section-6",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "tK8KS",
                  "name": "p6t",
                  "fill": "$text-primary",
                  "content": "6. Data Retention",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "RsERD",
                  "name": "p6b",
                  "fill": "$text-secondary",
                  "content": "We retain your personal data only for as long as necessary to fulfill the purposes outlined in this policy. Transaction records are retained for compliance with legal and financial obligations. You may request deletion of your account data at any time.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "pfy06",
              "name": "section-7",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "C5Cu2",
                  "name": "p7t",
                  "fill": "$text-primary",
                  "content": "7. Security Measures",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "pNiAn",
                  "name": "p7b",
                  "fill": "$text-secondary",
                  "content": "We implement industry-standard security measures including encryption, secure socket layer (SSL) technology, and regular security audits to protect your personal information. However, no method of transmission over the internet is 100% secure.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "3xEdx",
              "name": "section-8",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "FpaFq",
                  "name": "p8t",
                  "fill": "$text-primary",
                  "content": "8. Changes to This Policy",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "rebqF",
                  "name": "p8b",
                  "fill": "$text-secondary",
                  "content": "We may update this Privacy Policy from time to time. We will notify you of any material changes by posting the new policy on this page and updating the \"Last updated\" date. We encourage you to review this policy periodically.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "iF9Zm",
              "name": "section-contact",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "text",
                  "id": "7l7Fx",
                  "name": "p9t",
                  "fill": "$text-primary",
                  "content": "9. Contact Us",
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "ovarz",
                  "name": "p9b",
                  "fill": "$text-secondary",
                  "content": "If you have any questions about this Privacy Policy or wish to exercise your data protection rights, please contact us at privacy@looply.com.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        }
      ]
