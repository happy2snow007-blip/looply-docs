                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "You may not use Looply to sell counterfeit goods, engage in fraudulent transactions, harass other users, or violate any applicable laws. We reserve the right to suspend or terminate accounts that violate these terms.",
