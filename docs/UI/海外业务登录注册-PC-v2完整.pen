                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "3TGIz",
                  "name": "section-2",
                  "width": "fill_container",
                  "layout": "vertical",
