                },
                {
                  "type": "text",
                  "id": "jITpk",
                  "name": "ppIntro",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "At Looply, we take your privacy seriously. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our platform.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "67gYb",
                  "name": "section-1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "yJwDC",
                      "name": "ppS1Title",
                      "fill": "$text-primary",
                      "content": "1. Information We Collect",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "w6pk2",
                      "name": "ppS1Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We collect information you provide directly to us, such as when you create an account, make a purchase, list an item for sale, or contact us for support. This includes your name, email address, shipping address, payment information, and any other information you choose to provide.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "1QNAr",
                  "name": "section-2",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "GcueS",
                      "name": "ppS2Title",
                      "fill": "$text-primary",
                      "content": "2. How We Use Your Information",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "c6mtz",
                      "name": "ppS2Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We use the information we collect to provide, maintain, and improve our services, process transactions, send you technical notices and support messages, and respond to your comments and questions.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "rCwaW",
                  "name": "section-3",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "oYxPJ",
                      "name": "ppS3Title",
                      "fill": "$text-primary",
                      "content": "3. Data Sharing and Disclosure",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "PFtIM",
                      "name": "ppS3Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We do not sell your personal information. We may share your data with third-party service providers who assist us in operating our platform, processing payments, and delivering items. All partners are contractually required to protect your information.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "3ALrN",
                  "name": "section-4",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "rpMAz",
                      "name": "ppS4Title",
                      "fill": "$text-primary",
                      "content": "4. Data Security",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "R5EcE",
                      "name": "ppS4Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We implement industry-standard security measures including encryption, secure socket layer technology, and regular security audits to protect your personal information from unauthorized access, alteration, or destruction.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "nVqC9",
                  "name": "section-5",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "3G2KB",
                      "name": "ppS5Title",
                      "fill": "$text-primary",
                      "content": "5. Your Rights and Choices",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "7svNA",
                      "name": "ppS5Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "You may access, update, or delete your personal information at any time through your account settings. You can opt out of marketing communications while still receiving essential service notifications. California residents have additional rights under the CCPA.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "lcs5X",
                  "name": "section-6",
                  "width": "fill_container",
                  "layout": "vertical",
