                      "name": "tsS2Title",
                      "fill": "$text-primary",
                      "content": "2. Buying and Selling",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "IUx2n",
                      "name": "tsS2Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Looply provides a platform for users to buy and sell pre-owned luxury goods. All items listed must be authentic and accurately described. We reserve the right to remove listings that violate our policies.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "mWhd3",
                  "name": "section-3",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "amJx4",
                      "name": "tsS3Title",
                      "fill": "$text-primary",
                      "content": "3. Authentication and Quality Guarantee",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "BlM0V",
                      "name": "tsS3Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Every item sold on Looply undergoes our multi-point authentication process. We guarantee the authenticity of all items purchased through our platform. If an item is found to be inauthentic, we will provide a full refund.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "TVwIV",
                  "name": "section-4",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
