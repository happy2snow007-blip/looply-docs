          "name": "content-area",
          "width": "fill_container",
          "height": "fill_container",
          "padding": [
            48,
            40
          ],
          "justifyContent": "center",
          "children": [
            {
              "type": "frame",
              "id": "q08Vb",
              "name": "article",
              "width": 720,
              "layout": "vertical",
              "gap": 32,
              "children": [
                {
                  "type": "text",
                  "id": "qCqsn",
                  "name": "ppTitle",
                  "fill": "$text-primary",
                  "content": "Privacy Policy",
                  "fontFamily": "DM Sans",
                  "fontSize": 32,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "Ye8jb",
                  "name": "ppUpdated",
                  "fill": "$text-tertiary",
                  "content": "Last updated: March 1, 2026",
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "01je3",
                  "name": "ppIntro",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "At Looply, we take your privacy seriously. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our platform.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "Basvb",
                  "name": "section-1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "3SWsS",
                      "name": "ppS1Title",
                      "fill": "$text-primary",
                      "content": "1. Information We Collect",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "pXS6n",
                      "name": "ppS1Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We collect information you provide directly to us, such as when you create an account, make a purchase, list an item for sale, or contact us for support. This includes your name, email address, shipping address, payment information, and any other information you choose to provide.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "uIjpk",
                  "name": "section-2",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "ltxiL",
                      "name": "ppS2Title",
                      "fill": "$text-primary",
                      "content": "2. How We Use Your Information",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "D6eiD",
                      "name": "ppS2Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We use the information we collect to provide, maintain, and improve our services, process transactions, send you technical notices and support messages, and respond to your comments and questions.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "6RTBn",
                  "name": "section-3",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "l89UB",
                      "name": "ppS3Title",
                      "fill": "$text-primary",
                      "content": "3. Data Sharing and Disclosure",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "inZsN",
                      "name": "ppS3Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We do not sell your personal information. We may share your data with third-party service providers who assist us in operating our platform, processing payments, and delivering items. All partners are contractually required to protect your information.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
