                      "name": "s2h",
                      "fill": "$text-primary",
                      "content": "2. How We Use Your Information",
                      "fontFamily": "Bricolage Grotesque",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "7S5r7",
                      "name": "s2p",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We use your information to: (a) provide and maintain our Service; (b) process transactions and send related information; (c) send you technical notices, updates, and support messages; (d) respond to your comments and questions; (e) detect, investigate, and prevent fraudulent transactions and other illegal activities; (f) personalize and improve your experience.",
                      "lineHeight": 1.7,
                      "fontFamily": "DM Sans",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
