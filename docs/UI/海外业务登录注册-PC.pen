                  "children": [
                    {
                      "type": "text",
                      "id": "SOPhm",
                      "name": "s1h",
                      "fill": "$text-primary",
                      "content": "1. Information We Collect",
                      "fontFamily": "Bricolage Grotesque",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "LJdvh",
                      "name": "s1p",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We collect information you provide directly, such as your name, email address, shipping address, payment information, and any content you submit. We also automatically collect device information, IP address, browser type, operating system, usage data, and cookies when you interact with our Service.",
                      "lineHeight": 1.7,
                      "fontFamily": "DM Sans",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
