                      "content": "6. Contact Us",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "tz7sf",
                      "name": "ppS6Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "If you have questions about this Privacy Policy or our data practices, please contact us at privacy@looply.com or through the Help Center in your account settings.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                }
