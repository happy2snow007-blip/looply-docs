                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "C7lIW",
                  "name": "tsIntro",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Welcome to Looply. By accessing or using our platform, you agree to be bound by these Terms of Service. Please read them carefully before using our services.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "KRl3g",
                  "name": "section-1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "HKc9Z",
                      "name": "tsS1Title",
                      "fill": "$text-primary",
                      "content": "1. Account Registration",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "fuYZo",
                      "name": "tsS1Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "To use certain features of our platform, you must register for an account. You agree to provide accurate, current, and complete information during registration and to update such information to keep it accurate.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "3TGIz",
                  "name": "section-2",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "7yF50",
                      "name": "tsS2Title",
                      "fill": "$text-primary",
                      "content": "2. Buying and Selling",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "IUx2n",
                      "name": "tsS2Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Looply provides a platform for users to buy and sell pre-owned luxury goods. All items listed must be authentic and accurately described. We reserve the right to remove listings that violate our policies.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "mWhd3",
                  "name": "section-3",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "amJx4",
                      "name": "tsS3Title",
                      "fill": "$text-primary",
                      "content": "3. Authentication and Quality Guarantee",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "BlM0V",
                      "name": "tsS3Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Every item sold on Looply undergoes our multi-point authentication process. We guarantee the authenticity of all items purchased through our platform. If an item is found to be inauthentic, we will provide a full refund.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "TVwIV",
                  "name": "section-4",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "SBGhd",
                      "name": "tsS4Title",
                      "fill": "$text-primary",
                      "content": "4. Payments and Fees",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "q0PJs",
                      "name": "tsS4Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Buyers pay the listed price plus applicable shipping and taxes. Sellers are charged a commission fee on completed sales. All payments are processed securely through our payment partners. Payouts to sellers are initiated after the buyer confirms receipt.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "xEweK",
                  "name": "section-5",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "0BnuK",
                      "name": "tsS5Title",
                      "fill": "$text-primary",
                      "content": "5. Prohibited Conduct",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "GfR9V",
                      "name": "tsS5Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "You may not use Looply to sell counterfeit goods, engage in fraudulent transactions, harass other users, or violate any applicable laws. We reserve the right to suspend or terminate accounts that violate these terms.",
                      "lineHeight": 1.6,
                      "fontFamily": "DM Sans",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "16SMT",
                  "name": "section-6",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "QnVSX",
                      "name": "tsS6Title",
                      "fill": "$text-primary",
                      "content": "6. Limitation of Liability",
                      "fontFamily": "DM Sans",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "dcrSg",
                      "name": "tsS6Body",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Looply provides the platform on an \"as is\" basis. We are not liable for any indirect, incidental, or consequential damages arising from your use of the platform. Our total liability shall not exceed the amount you paid in fees during the preceding 12 months.",
                      "lineHeight": 1.6,
